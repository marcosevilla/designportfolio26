# drei v10 declares a react@^19 peer, but Next 16's App Router runs vendored
# React 19 internals regardless of our react 18.3 pin, so the pairing works
# at runtime (see CLAUDE.md, logo-lab session 2026-07-17). Local installs
# already used --legacy-peer-deps; this makes Vercel's clean install match.
legacy-peer-deps=true
